
type Consumer<T> = (msg: T) => Promise<void> | void;

class ProducerConsumer<T> {
  private queue: T[] = []; // stores messages
  private consumers: Map<number, Consumer<T>> = new Map(); // id -> consumer
  private isProcessing: boolean = false; // prevents multiple loops
  private idCounter: number = 0; // unique id for consumers

  publish(message: T): void {
    console.log("\n📦 Produced:", message);

    // add message to queue
    this.queue.push(message);

    // start processing
    this.process();
  }

  subscribe(fn: Consumer<T>): { id: number; unsubscribe: () => void } {
    const id = ++this.idCounter;

    // store consumer
    this.consumers.set(id, fn);

    console.log(`✅ Consumer ${id} subscribed`);

    // return both id and unsubscribe function
    return {
      id,
      unsubscribe: () => this.unsubscribe(id),
    };
  }

  unsubscribe(id: number): void {
    if (this.consumers.has(id)) {
      this.consumers.delete(id);
      console.log(`❌ Consumer ${id} unsubscribed`);
    }
  }

  private async process(): Promise<void> {
    // prevent multiple parallel loops
    if (this.isProcessing) return;

    this.isProcessing = true;

    // process messages one by one
    while (this.queue.length > 0) {
      const msg = this.queue.shift()!;

      console.log("🚚 Processing message:", msg);

      // 🔥 SNAPSHOT (VERY IMPORTANT)
      // We copy consumers so changes during iteration don't break loop
      const consumersSnapshot = Array.from(this.consumers.entries());

      for (let [id, consumer] of consumersSnapshot) {
        console.log(`➡️ Sending to Consumer ${id}`);

        // await ensures order + async safety
        await consumer(msg);
      }
    }

    this.isProcessing = false;
  }
}

const pc = new ProducerConsumer<string>();

// Consumer 1
const c1 = pc.subscribe(async (msg) => {
  console.log("👤 Consumer 1 got:", msg);
});

// Consumer 2
const c2 = pc.subscribe(async (msg) => {
  console.log("👤 Consumer 2 got:", msg);
});


pc.publish("A");
pc.publish("B");

setTimeout(() => {
  c1.unsubscribe(); // remove consumer 1
}, 500);

setTimeout(() => {
  pc.publish("C");
}, 1000);

setTimeout(() => {
  const c3 = pc.subscribe(async (msg) => {
    console.log("👤 Consumer 3 got:", msg);
  });

  pc.publish("D");

  // unsubscribe using ID method
  setTimeout(() => {
    pc.unsubscribe(c3.id);
  }, 500);
}, 1500);

setTimeout(() => {
  pc.publish("E");
}, 2500);
