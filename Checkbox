import React, { useState } from "react";

// --- Types ---
type CheckboxItem = {
  id: number;
  name: string;
  checked: boolean | "indeterminate";
  children?: CheckboxItem[];
};

// --- Main App Component ---
export default function App() {
  const checkboxesData: CheckboxItem[] = [
    {
      id: 1,
      name: "Electronics",
      checked: false,
      children: [
        {
          id: 2,
          name: "Mobile phones",
          checked: false,
          children: [
            { id: 3, name: "iPhone", checked: false },
            { id: 4, name: "Android", checked: false },
          ],
        },
        {
          id: 5,
          name: "Laptops",
          checked: false,
          children: [
            { id: 6, name: "MacBook", checked: false },
            { id: 7, name: "Surface Pro", checked: false },
          ],
        },
      ],
    },
    {
      id: 8,
      name: "Books",
      checked: false,
      children: [
        { id: 9, name: "Fiction", checked: false },
        { id: 10, name: "Non-fiction", checked: false },
      ],
    },
    { id: 11, name: "Toys", checked: false },
  ];

  const [tree, setTree] = useState<CheckboxItem[]>(checkboxesData);

  // 1. Recursive helper to force all descendants to match the parent's new state
  const updateChildrenRecursive = (node: CheckboxItem, isChecked: boolean): CheckboxItem => {
    return {
      ...node,
      checked: isChecked,
      children: node.children?.map((child) => updateChildrenRecursive(child, isChecked)),
    };
  };

  // 2. Main recursive function to find the target and update parents on the way up
  const updateTree = (data: CheckboxItem[], targetId: number): CheckboxItem[] => {
    return data.map((node) => {
      let newNode = { ...node };

      if (newNode.id === targetId) {
        // Toggle logic: If true, go false. If false or indeterminate, go true.
        const nextStatus = newNode.checked === true ? false : true;
        return updateChildrenRecursive(newNode, nextStatus);
      }

      if (newNode.children) {
        newNode.children = updateTree(newNode.children, targetId);

        // After updating children, determine this node's status based on them
        const allChecked = newNode.children.every((c) => c.checked === true);
        const noneChecked = newNode.children.every((c) => c.checked === false);
        const someCheckedOrIndeterminate = newNode.children.some(
          (c) => c.checked === true || c.checked === "indeterminate"
        );

        if (allChecked) {
          newNode.checked = true;
        } else if (someCheckedOrIndeterminate) {
          newNode.checked = "indeterminate";
        } else {
          newNode.checked = false;
        }
      }

      return newNode;
    });
  };

  const handleClick = (id: number) => {
    setTree((prevTree) => updateTree(prevTree, id));
  };

  // 3. Recursive Render Helper
  const renderCheckboxes = (data: CheckboxItem[]) => {
    return data.map((item) => (
      <div key={item.id} style={{ marginLeft: 20, userSelect: "none" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "8px", margin: "4px 0" }}>
          <div
            onClick={() => handleClick(item.id)}
            style={{
              width: 16,
              height: 16,
              border: "1px solid #333",
              borderRadius: "3px",
              alignItems: "center",
              justifyContent: "center",
              backgroundColor: item.checked === true ? "red" : "white",
              transition: "background-color 0.2s",
            }}
          >
            {item.checked === "indeterminate" && (
              <div style={{ width: 8, height: 2, backgroundColor: "#666" }} />
            )}
          </div>
          <span style={{ fontSize: "14px", fontFamily: "sans-serif" }}>{item.name}</span>
        </div>
        {item.children && renderCheckboxes(item.children)}
      </div>
    ));
  };

  return (
    <div style={{ padding: "20px" }}>
      <h2>Recursive Checkbox Tree</h2>
      <hr />
      {renderCheckboxes(tree)}
    </div>
  );
}
