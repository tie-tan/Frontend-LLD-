// TaskQueue.ts

type TaskFn<T> = () => Promise<T>

type Executor = <T>(task: TaskFn<T>, taskId: string) => Promise<T>

interface Task<T> {
  id: string
  fn: TaskFn<T>
  onSuccess?: (result: T) => void
  onError?: (error: any) => void
}

class TaskQueue {
  private concurrency: number
  private runningCount: number = 0
  private queue: Task<any>[] = []
  private executor: Executor

  constructor(concurrency: number, executor?: Executor) {
    this.concurrency = concurrency
    this.executor = executor || this.defaultExecutor
  }

  private defaultExecutor: Executor = async <T>(task: TaskFn<T>) => {
    return task()
  }

  addTask<T>(task: Task<T>) {
    this.queue.push(task)
    this.runNext()
  }

  private runNext() {
    while (this.runningCount < this.concurrency && this.queue.length > 0) {
      const task = this.queue.shift()!
      this.executeTask(task)
    }
  }

  private async executeTask<T>(task: Task<T>) {
    this.runningCount++

    try {
      const result = await this.executor(task.fn, task.id)
      task.onSuccess?.(result)
    } catch (error) {
      task.onError?.(error)
    } finally {
      this.runningCount--
      this.runNext()
    }
  }

  getRunningCount() {
    return this.runningCount
  }

  getQueueSize() {
    return this.queue.length
  }
}

// ------------------ Usage Example ------------------

const retryExecutor: Executor = async <T>(task, id) => {
  let attempts = 3

  while (attempts--) {
    try {
      console.log(`Running ${id}, attempts left: ${attempts}`)
      return await task()
    } catch (e) {
      if (attempts === 0) throw e
    }
  }

  throw new Error("Unreachable")
}

const queue = new TaskQueue(2, retryExecutor)

const createTask = (id: string, delay: number): Task<number> => ({
  id,
  fn: () =>
    new Promise((resolve) => {
      setTimeout(() => {
        console.log(`Task ${id} completed`)
        resolve(delay)
      }, delay)
    }),
  onSuccess: (res) => console.log(`Success ${id}:`, res),
  onError: (err) => console.log(`Error ${id}:`, err),
})

// Add tasks
queue.addTask(createTask("A", 2000))
queue.addTask(createTask("B", 1000))
queue.addTask(createTask("C", 3000))
queue.addTask(createTask("D", 500))
